if text.capitalize() in [
    "Таухид","Ширк","Иман","Ислам","Ихсан","Намаз","Пост","Закят","Хадж",
    "Ду'а","Акида","Судный день","Ангелы","Пророки","Коран","Сунна","Хадисы",
    "Фикх","Нравственность","Чистота","Брак","Семья","Дети","Одежда",
    "Халяль","Харам","Торговля","Милостыня","Джума","Джаназа","Мечеть",
    "Адабы","Умма","Джихад","Ночь предопределения","Рамадан","Шавваль",
    "Зуль-хиджа","Ид аль-Фитр","Ид аль-Адха","Имена Аллаха","Сира",
    "Сподвижники","Табиины","Имамы","Учёные","Истории из Корана"
]:
    answer = ask_groq(f"Объясни тему: {text}")
    update.message.reply_text(answer)
    return
# Если выбрана главная тема — показать подкатегории
if text.capitalize() in subtopics:
    update.message.reply_text(
        f"Выбери подкатегорию темы «{text.capitalize()}»:",
        reply_markup=ReplyKeyboardMarkup(
            [subtopics[text.capitalize()]],
            resize_keyboard=True
        )
    )
    return

# Если выбрана подкатегория — отправить запрос в Groq
for main_topic, subs in subtopics.items():
    if text in subs:
        answer = ask_groq(f"Объясни тему: {main_topic}. Подкатегория: {text}.")
        update.message.reply_text(answer)
        return
